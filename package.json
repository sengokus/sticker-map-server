{
    "name": "expressjs-starter",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "dev": "npx dotenv -e .env.dev -- tsc && tsc-alias && node dist/index.js",
        "test": "echo \"Error: no test specified\" && exit 1",
        "start": "node ./dist/index.js",
        "build": "npx prisma generate && npx tsc -p . && tsc-alias",
        "db:create-migrate:dev": "npx prisma migrate dev --create-only",
        "db:migrate:dev": "npx prisma migrate dev",
        "db:migrate:prod": "npx dotenv -e .env.prod -- npx prisma migrate deploy",
        "format": "prettier --ignore-path .gitignore --write \"**/*.{js,ts,json}\""
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/client": "^5.9.1",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.20",
        "@types/lodash": "^4.14.202",
        "@types/luxon": "^3.4.2",
        "@types/node": "^20.8.10",
        "@types/uuid": "^9.0.8",
        "axios": "^1.6.8",
        "body-parser": "^1.20.2",
        "cors": "^2.8.5",
        "deepmerge": "^4.3.1",
        "dotenv": "^16.3.1",
        "dotenv-cli": "^7.3.0",
        "express": "^4.18.2",
        "lodash": "^4.17.21",
        "luxon": "^3.4.4",
        "prisma": "^5.9.1",
        "ts-node": "^10.9.1",
        "tsc-alias": "^1.8.8",
        "typescript": "^5.2.2",
        "uuid": "^9.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^4.3.0",
        "prettier": "3.2.5"
    }
}
